<!DOCTYPE html>
<html>
<head>

<title>Abdullah Clothes Shop</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/style.css">

</head>

<body>

<!-- Navbar -->

<nav class="navbar navbar-dark bg-dark shadow">

<div class="container">

<a class="navbar-brand fs-3 fw-bold">Abdullah Clothes Shop</a>

</div>

</nav>


<!-- Hero Section -->

<div class="hero text-center text-white">

<h1 class="display-4">Premium Fashion Collection</h1>

<p>Best Clothes For Men & Women</p>

</div>


<!-- Products -->

<div class="container mt-5">

<div class="row g-4">

<% products.forEach(product => { %>

<div class="col-md-4">

<div class="card product-card">

<img src="<%= product.image %>" class="card-img-top">

<div class="card-body text-center">

<h5 class="card-title"><%= product.name %></h5>

<p class="price">₹ <%= product.price %></p>

<a href="/product/<%= product.id %>" class="btn btn-dark w-100">
View Product
</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>


<footer class="footer text-center text-white mt-5">

<p>© 2026 Abdullah Clothes Shop</p>

</footer>

</body>
</html>